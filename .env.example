# --- Order pipeline (retry + compensation) ---
# SQLite order database (created automatically; keep on a durable volume)
ORDER_DB_PATH=data/orders.db
# Mint/refund retry policy
MINT_MAX_ATTEMPTS=5
REFUND_MAX_ATTEMPTS=5
RETRY_BASE_MS=2000
RETRY_CAP_MS=60000
RETRY_TICK_MS=4000
# Bearer token guarding GET /admin/orders (leave empty to disable the route)
ADMIN_TOKEN=