SERVER_PRIVATE_KEY=0x...
SERVER_ADDRESS=0x...
ARC_RPC_URL=

GAME_PAYMENT_ADDRESS=0x...
NPC_NFT_ADDRESS=0x...
# NPC_CHARACTER_ADDRESS is also accepted as an alias for NPC_NFT_ADDRESS.
NPC_CHARACTER_ADDRESS=
NPC_MARKETPLACE_ADDRESS=
NPC_PRICING_ADDRESS=
USDC_ADDRESS=
GATEWAY_WALLET_ADDRESS=
ERC6551_REGISTRY=0x...
ERC6551_IMPLEMENTATION=0x...

# Optional: restrict TBA execution to specific target addresses (comma-separated; leave empty to allow all)
TBA_EXECUTE_ALLOWED_TARGETS=

# --- Order pipeline (retry + compensation) ---
# SQLite order database (created automatically; keep on a durable volume)
ORDER_DB_PATH=data/orders.db
# Mint/refund retry policy
MINT_MAX_ATTEMPTS=5
REFUND_MAX_ATTEMPTS=5
RETRY_BASE_MS=2000
RETRY_CAP_MS=60000
RETRY_TICK_MS=4000
# Bearer token guarding GET /admin/orders (leave empty to disable the route)
ADMIN_TOKEN=
